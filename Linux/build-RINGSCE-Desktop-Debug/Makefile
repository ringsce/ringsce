####### Compile

main.o: ../RINGSCE/main.cpp ../RINGSCE/mainwindow.h \
		../RINGSCE/highlighter.h \
		../RINGSCE/splashscreen.h \
		../RINGSCE/ui_new_file.h \
		../RINGSCE/ui_new_project.h \
		../RINGSCE/ui_below_stack.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o ../RINGSCE/main.cpp

mainwindow.o: ../RINGSCE/mainwindow.cpp ../RINGSCE/mainwindow.h \
		ui_mainwindow.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o mainwindow.o ../RINGSCE/mainwindow.cpp

highlighter.o: ../RINGSCE/highlighter.cpp ../RINGSCE/highlighter.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o highlighter.o ../RINGSCE/highlighter.cpp

new_file.o: ../RINGSCE/new_file.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o new_file.o ../RINGSCE/new_file.cpp

settings.o: ../RINGSCE/settings.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o settings.o ../RINGSCE/settings.cpp

about.o: ../RINGSCE/about.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o about.o ../RINGSCE/about.cpp

update.o: ../RINGSCE/update.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o update.o ../RINGSCE/update.cpp

new_project.o: ../RINGSCE/new_project.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o new_project.o ../RINGSCE/new_project.cpp

splashscreen.o: ../RINGSCE/splashscreen.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o splashscreen.o ../RINGSCE/splashscreen.cpp

qrc_style.o: qrc_style.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o qrc_style.o qrc_style.cpp

moc_mainwindow.o: moc_mainwindow.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_mainwindow.o moc_mainwindow.cpp

moc_highlighter.o: moc_highlighter.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_highlighter.o moc_highlighter.cpp

